# =====================================================
# Aboud Trading Bot - Environment Variables Template
# =====================================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!
# =====================================================

# Telegram Bot Token (get from @BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Telegram Channel ID (starts with -100 for channels)
TELEGRAM_CHAT_ID=-100xxxxxxxxxx

# Admin User IDs (comma-separated Telegram user IDs)
# Get your user ID from @userinfobot
ADMIN_USER_IDS=your_telegram_user_id

# Webhook Secret (must match Pine Script webhook_secret)
WEBHOOK_SECRET=aboud_trading_secret_2024

# Signals enabled on startup
SIGNALS_ENABLED=true

# UTC offset for your timezone (0 = UTC)
BOT_UTC_OFFSET=0

# Daily report time (hour in UTC, 0-23)
DAILY_REPORT_HOUR=21

# Port for webhook server
PORT=10000

# Debug mode
DEBUG=false
