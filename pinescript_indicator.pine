// =====================================================
// ABOUD TRADING BOT PRO - Pine Script v5.2 (FINAL)
// =====================================================
// Min score lowered to 6/10
// target_entry_time = time_close (immediate next candle)
// =====================================================

//@version=5
indicator("Aboud Trading PRO 15M", overlay=true, shorttitle="ABOUD PRO")

ema_fast_len   = input.int(9,   "EMA Fast",   minval=3,   maxval=50,  group="📊 EMA")
ema_mid_len    = input.int(21,  "EMA Mid",    minval=10,  maxval=100, group="📊 EMA")
ema_slow_len   = input.int(50,  "EMA Slow",   minval=20,  maxval=200, group="📊 EMA")
ema_trend_len  = input.int(200, "EMA Trend",  minval=100, maxval=400, group="📊 EMA")
rsi_len        = input.int(14,    "RSI Period",       minval=5,  maxval=30,  group="📈 RSI")
rsi_call_min   = input.float(55,  "RSI Min CALL",     minval=50, maxval=70,  group="📈 RSI")
rsi_put_max    = input.float(45,  "RSI Max PUT",      minval=30, maxval=50,  group="📈 RSI")
macd_fast      = input.int(12, "MACD Fast",   minval=5,  maxval=30, group="📉 MACD")
macd_slow      = input.int(26, "MACD Slow",   minval=15, maxval=50, group="📉 MACD")
macd_signal    = input.int(9,  "MACD Signal", minval=3,  maxval=20, group="📉 MACD")
st_period      = input.int(10,   "ST Period",     minval=5,   maxval=30,  group="🔄 Supertrend")
st_multiplier  = input.float(2.0, "ST Multiplier", minval=1.0, maxval=5.0, step=0.1, group="🔄 Supertrend")
adx_len        = input.int(14,    "ADX Period",    minval=5,  maxval=30, group="💪 ADX")
adx_min        = input.float(25,  "ADX Min",       minval=15, maxval=40, group="💪 ADX")
bb_len         = input.int(20,    "BB Period",     minval=10, maxval=50, group="📏 BB")
bb_mult        = input.float(2.0, "BB Mult",       minval=1.0, maxval=3.0, step=0.1, group="📏 BB")
stoch_len      = input.int(14, "Stoch Len",    minval=5, maxval=30, group="🔀 StochRSI")
stoch_k        = input.int(3,  "Stoch %K",     minval=1, maxval=10, group="🔀 StochRSI")
stoch_d        = input.int(3,  "Stoch %D",     minval=1, maxval=10, group="🔀 StochRSI")
stoch_call_min = input.float(30, "Stoch Min CALL", minval=10, maxval=50, group="🔀 StochRSI")
stoch_put_max  = input.float(70, "Stoch Max PUT",  minval=50, maxval=90, group="🔀 StochRSI")
atr_len        = input.int(14,    "ATR Period",     minval=5,   maxval=30,  group="📏 Candle")
min_body_ratio = input.float(0.4, "Min Body Ratio", minval=0.1, maxval=0.8, step=0.05, group="📏 Candle")
max_atr_mult   = input.float(2.0, "Max ATR Ratio",  minval=1.0, maxval=5.0, step=0.1,  group="📏 Candle")
min_score      = input.int(6,  "Min Score", minval=4, maxval=10, group="🎯 Score")
cooldown_bars  = input.int(3, "Cooldown bars", minval=1, maxval=10, group="🎯 Score")
show_signals   = input.bool(true, "Arrows",     group="🎨 Display")
show_ema       = input.bool(true, "EMAs",       group="🎨 Display")
show_supertrend= input.bool(true, "Supertrend", group="🎨 Display")
show_bb        = input.bool(true, "BB",         group="🎨 Display")
show_score     = input.bool(true, "Score Table",group="🎨 Display")
webhook_secret = input.string("aboud_trading_secret_2024", "Secret", group="🔔 Alert")

// CALCULATIONS
ema_fast   = ta.ema(close, ema_fast_len)
ema_mid    = ta.ema(close, ema_mid_len)
ema_slow   = ta.ema(close, ema_slow_len)
ema_trend  = ta.ema(close, ema_trend_len)

score_ema_call   = ema_fast > ema_mid and ema_mid > ema_slow ? 1 : 0
score_ema_put    = ema_fast < ema_mid and ema_mid < ema_slow ? 1 : 0
score_trend_call = close > ema_trend ? 1 : 0
score_trend_put  = close < ema_trend ? 1 : 0

rsi_val = ta.rsi(close, rsi_len)
score_rsi_call = rsi_val > rsi_call_min and rsi_val < 75 ? 1 : 0
score_rsi_put  = rsi_val < rsi_put_max and rsi_val > 25 ? 1 : 0

[macd_line, signal_line, hist_val] = ta.macd(close, macd_fast, macd_slow, macd_signal)
score_macd_call = hist_val > 0 and hist_val > hist_val[1] ? 1 : 0
score_macd_put  = hist_val < 0 and hist_val < hist_val[1] ? 1 : 0

[st_line, st_dir] = ta.supertrend(st_multiplier, st_period)
st_bullish = st_dir < 0
st_bearish = st_dir > 0
score_st_call = st_bullish ? 1 : 0
score_st_put  = st_bearish ? 1 : 0

dmi_plus  = ta.change(ta.highest(high, 1))
dmi_minus = -ta.change(ta.lowest(low, 1))
tr_val    = ta.tr(true)
plus_dm   = dmi_plus > dmi_minus and dmi_plus > 0 ? dmi_plus : 0
minus_dm  = dmi_minus > dmi_plus and dmi_minus > 0 ? dmi_minus : 0
smoothed_tr    = ta.rma(tr_val, adx_len)
smoothed_plus  = ta.rma(plus_dm, adx_len)
smoothed_minus = ta.rma(minus_dm, adx_len)
plus_di  = smoothed_tr != 0 ? (smoothed_plus / smoothed_tr) * 100 : 0
minus_di = smoothed_tr != 0 ? (smoothed_minus / smoothed_tr) * 100 : 0
dx       = (plus_di + minus_di) != 0 ? math.abs(plus_di - minus_di) / (plus_di + minus_di) * 100 : 0
adx_val  = ta.rma(dx, adx_len)
score_adx_call = adx_val > adx_min and plus_di > minus_di ? 1 : 0
score_adx_put  = adx_val > adx_min and minus_di > plus_di ? 1 : 0

bb_basis = ta.sma(close, bb_len)
bb_dev   = bb_mult * ta.stdev(close, bb_len)
bb_upper = bb_basis + bb_dev
bb_lower = bb_basis - bb_dev
score_bb_call = close > bb_basis and close < bb_upper ? 1 : 0
score_bb_put  = close < bb_basis and close > bb_lower ? 1 : 0

rsi_for_stoch = ta.rsi(close, stoch_len)
stoch_rsi_k   = ta.sma(ta.stoch(rsi_for_stoch, rsi_for_stoch, rsi_for_stoch, stoch_len), stoch_k)
stoch_rsi_d   = ta.sma(stoch_rsi_k, stoch_d)
score_stoch_call = stoch_rsi_k > stoch_call_min and stoch_rsi_k > stoch_rsi_d ? 1 : 0
score_stoch_put  = stoch_rsi_k < stoch_put_max and stoch_rsi_k < stoch_rsi_d ? 1 : 0

atr_val      = ta.atr(atr_len)
candle_range = high - low
candle_body  = math.abs(close - open)
body_ratio   = candle_range > 0 ? candle_body / candle_range : 0
atr_ratio    = atr_val > 0 ? candle_range / atr_val : 0
score_candle_call = body_ratio >= min_body_ratio and atr_ratio <= max_atr_mult and candle_range > 0 and close > open ? 1 : 0
score_candle_put  = body_ratio >= min_body_ratio and atr_ratio <= max_atr_mult and candle_range > 0 and close < open ? 1 : 0

ema_1h_fast = request.security(syminfo.tickerid, "60", ta.ema(close, 9))
ema_1h_slow = request.security(syminfo.tickerid, "60", ta.ema(close, 21))
ema_1h_trend = request.security(syminfo.tickerid, "60", ta.ema(close, 50))
score_mtf_call = ema_1h_fast > ema_1h_slow and close > ema_1h_trend ? 1 : 0
score_mtf_put  = ema_1h_fast < ema_1h_slow and close < ema_1h_trend ? 1 : 0

// TOTAL SCORE
call_score = score_ema_call + score_trend_call + score_rsi_call + score_macd_call + score_st_call + score_adx_call + score_bb_call + score_stoch_call + score_candle_call + score_mtf_call
put_score  = score_ema_put  + score_trend_put  + score_rsi_put  + score_macd_put  + score_st_put  + score_adx_put  + score_bb_put  + score_stoch_put  + score_candle_put  + score_mtf_put

// SIGNAL LOGIC
call_signal = call_score >= min_score
put_signal  = put_score  >= min_score

var int bars_since_call = 999
var int bars_since_put  = 999
bars_since_call := bars_since_call + 1
bars_since_put  := bars_since_put  + 1

new_call = call_signal and not call_signal[1] and bars_since_call >= cooldown_bars
new_put  = put_signal  and not put_signal[1]  and bars_since_put  >= cooldown_bars

if new_call
    bars_since_call := 0
if new_put
    bars_since_put := 0

call_disappeared = not call_signal and call_signal[1]
put_disappeared  = not put_signal  and put_signal[1]

// FIXED: target = next candle open (immediate)
next_entry_time = time_close

// PLOTTING
plot(show_ema ? ema_fast  : na, "EMA 9",   color=color.new(color.aqua,   0), linewidth=1)
plot(show_ema ? ema_mid   : na, "EMA 21",  color=color.new(color.blue,   0), linewidth=2)
plot(show_ema ? ema_slow  : na, "EMA 50",  color=color.new(color.orange, 0), linewidth=2)
plot(show_ema ? ema_trend : na, "EMA 200", color=color.new(color.purple, 0), linewidth=3)
st_color = st_bullish ? color.new(color.green, 20) : color.new(color.red, 20)
plot(show_supertrend ? st_line : na, "ST", color=st_color, linewidth=2, style=plot.style_linebr)
p_u = plot(show_bb ? bb_upper : na, "BBU", color=color.new(color.gray, 60))
p_l = plot(show_bb ? bb_lower : na, "BBL", color=color.new(color.gray, 60))
plot(show_bb ? bb_basis : na, "BBM", color=color.new(color.gray, 40), linewidth=1)
fill(p_u, p_l, color=color.new(color.gray, 92))
plotshape(show_signals and new_call, "CALL", style=shape.triangleup,   location=location.belowbar, color=color.new(color.green, 0), size=size.normal, text="CALL")
plotshape(show_signals and new_put,  "PUT",  style=shape.triangledown, location=location.abovebar, color=color.new(color.red, 0),   size=size.normal, text="PUT")
bgcolor(call_signal ? color.new(color.green, 94) : put_signal ? color.new(color.red, 94) : na)

// SCORE TABLE
var table t = table.new(position.top_right, 3, 14, bgcolor=color.new(color.black, 80), border_width=1)
if barstate.islast and show_score
    table.cell(t, 0, 0, "ABOUD PRO", text_color=color.white, bgcolor=color.new(color.blue, 30), text_size=size.small)
    table.cell(t, 1, 0, "CALL",      text_color=color.green, bgcolor=color.new(color.blue, 30), text_size=size.small)
    table.cell(t, 2, 0, "PUT",       text_color=color.red,   bgcolor=color.new(color.blue, 30), text_size=size.small)
    table.cell(t, 0, 1, "① EMA",     text_color=color.white, text_size=size.tiny)
    table.cell(t, 1, 1, str.tostring(score_ema_call),   text_color=score_ema_call   > 0 ? color.green : color.gray, text_size=size.tiny)
    table.cell(t, 2, 1, str.tostring(score_ema_put),    text_color=score_ema_put    > 0 ? color.green : color.gray, text_size=size.tiny)
    table.cell(t, 0, 2, "② EMA200",  text_color=color.white, text_size=size.tiny)
    table.cell(t, 1, 2, str.tostring(score_trend_call), text_color=score_trend_call > 0 ? color.green : color.gray, text_size=size.tiny)
    table.cell(t, 2, 2, str.tostring(score_trend_put),  text_color=score_trend_put  > 0 ? color.green : color.gray, text_size=size.tiny)
    table.cell(t, 0, 3, "③ RSI",     text_color=color.white, text_size=size.tiny)
    table.cell(t, 1, 3, str.tostring(score_rsi_call),   text_color=score_rsi_call   > 0 ? color.green : color.gray, text_size=size.tiny)
    table.cell(t, 2, 3, str.tostring(score_rsi_put),    text_color=score_rsi_put    > 0 ? color.green : color.gray, text_size=size.tiny)
    table.cell(t, 0, 4, "④ MACD",    text_color=color.white, text_size=size.tiny)
    table.cell(t, 1, 4, str.tostring(score_macd_call),  text_color=score_macd_call  > 0 ? color.green : color.gray, text_size=size.tiny)
    table.cell(t, 2, 4, str.tostring(score_macd_put),   text_color=score_macd_put   > 0 ? color.green : color.gray, text_size=size.tiny)
    table.cell(t, 0, 5, "⑤ ST",      text_color=color.white, text_size=size.tiny)
    table.cell(t, 1, 5, str.tostring(score_st_call),    text_color=score_st_call    > 0 ? color.green : color.gray, text_size=size.tiny)
    table.cell(t, 2, 5, str.tostring(score_st_put),     text_color=score_st_put     > 0 ? color.green : color.gray, text_size=size.tiny)
    table.cell(t, 0, 6, "⑥ ADX",     text_color=color.white, text_size=size.tiny)
    table.cell(t, 1, 6, str.tostring(score_adx_call),   text_color=score_adx_call   > 0 ? color.green : color.gray, text_size=size.tiny)
    table.cell(t, 2, 6, str.tostring(score_adx_put),    text_color=score_adx_put    > 0 ? color.green : color.gray, text_size=size.tiny)
    table.cell(t, 0, 7, "⑦ BB",      text_color=color.white, text_size=size.tiny)
    table.cell(t, 1, 7, str.tostring(score_bb_call),    text_color=score_bb_call    > 0 ? color.green : color.gray, text_size=size.tiny)
    table.cell(t, 2, 7, str.tostring(score_bb_put),     text_color=score_bb_put     > 0 ? color.green : color.gray, text_size=size.tiny)
    table.cell(t, 0, 8, "⑧ Stoch",   text_color=color.white, text_size=size.tiny)
    table.cell(t, 1, 8, str.tostring(score_stoch_call), text_color=score_stoch_call > 0 ? color.green : color.gray, text_size=size.tiny)
    table.cell(t, 2, 8, str.tostring(score_stoch_put),  text_color=score_stoch_put  > 0 ? color.green : color.gray, text_size=size.tiny)
    table.cell(t, 0, 9, "⑨ Candle",  text_color=color.white, text_size=size.tiny)
    table.cell(t, 1, 9, str.tostring(score_candle_call),text_color=score_candle_call> 0 ? color.green : color.gray, text_size=size.tiny)
    table.cell(t, 2, 9, str.tostring(score_candle_put), text_color=score_candle_put > 0 ? color.green : color.gray, text_size=size.tiny)
    table.cell(t, 0, 10, "⑩ 1H",    text_color=color.white, text_size=size.tiny)
    table.cell(t, 1, 10, str.tostring(score_mtf_call),  text_color=score_mtf_call   > 0 ? color.green : color.gray, text_size=size.tiny)
    table.cell(t, 2, 10, str.tostring(score_mtf_put),   text_color=score_mtf_put    > 0 ? color.green : color.gray, text_size=size.tiny)
    table.cell(t, 0, 11, "TOTAL",    text_color=color.yellow, bgcolor=color.new(color.blue, 50), text_size=size.small)
    table.cell(t, 1, 11, str.tostring(call_score)+"/10", text_color=call_score >= min_score ? color.green : color.gray, bgcolor=color.new(color.blue, 50), text_size=size.small)
    table.cell(t, 2, 11, str.tostring(put_score)+"/10",  text_color=put_score >= min_score ? color.green : color.gray, bgcolor=color.new(color.blue, 50), text_size=size.small)
    sig = call_signal ? "🟢 CALL("+str.tostring(call_score)+")" : put_signal ? "🔴 PUT("+str.tostring(put_score)+")" : "⚪ NONE"
    table.cell(t, 0, 12, "Signal", text_color=color.white, text_size=size.tiny)
    table.cell(t, 1, 12, sig,      text_color=color.white, text_size=size.tiny)
    table.cell(t, 2, 12, "",       text_size=size.tiny)
    table.cell(t, 0, 13, "RSI/ADX",text_color=color.white, text_size=size.tiny)
    table.cell(t, 1, 13, str.tostring(rsi_val,"#.#")+"/"+str.tostring(adx_val,"#.#"), text_color=color.white, text_size=size.tiny)
    table.cell(t, 2, 13, "",       text_size=size.tiny)

// ALERTS
if new_call
    a = '{"secret":"'+webhook_secret+'","pair":"'+syminfo.ticker+'","direction":"CALL","action":"SIGNAL","signal_score":'+str.tostring(call_score)+',"target_entry_time":'+str.tostring(next_entry_time)+',"signal_time":'+str.tostring(time_close)+',"signal_close":'+str.tostring(close)+',"indicators":{"ema_fast":'+str.tostring(ema_fast)+',"ema_mid":'+str.tostring(ema_mid)+',"ema_slow":'+str.tostring(ema_slow)+',"ema200":'+str.tostring(ema_trend)+',"rsi":'+str.tostring(rsi_val)+',"macd_hist":'+str.tostring(hist_val)+',"supertrend":"UP","adx":'+str.tostring(adx_val)+',"stoch_k":'+str.tostring(stoch_rsi_k)+',"bb_basis":'+str.tostring(bb_basis)+'}}'
    alert(a, alert.freq_once_per_bar)

if new_put
    a = '{"secret":"'+webhook_secret+'","pair":"'+syminfo.ticker+'","direction":"PUT","action":"SIGNAL","signal_score":'+str.tostring(put_score)+',"target_entry_time":'+str.tostring(next_entry_time)+',"signal_time":'+str.tostring(time_close)+',"signal_close":'+str.tostring(close)+',"indicators":{"ema_fast":'+str.tostring(ema_fast)+',"ema_mid":'+str.tostring(ema_mid)+',"ema_slow":'+str.tostring(ema_slow)+',"ema200":'+str.tostring(ema_trend)+',"rsi":'+str.tostring(rsi_val)+',"macd_hist":'+str.tostring(hist_val)+',"supertrend":"DOWN","adx":'+str.tostring(adx_val)+',"stoch_k":'+str.tostring(stoch_rsi_k)+',"bb_basis":'+str.tostring(bb_basis)+'}}'
    alert(a, alert.freq_once_per_bar)

if call_disappeared
    alert('{"secret":"'+webhook_secret+'","pair":"'+syminfo.ticker+'","direction":"CALL","action":"CANCEL"}', alert.freq_once_per_bar)

if put_disappeared
    alert('{"secret":"'+webhook_secret+'","pair":"'+syminfo.ticker+'","direction":"PUT","action":"CANCEL"}', alert.freq_once_per_bar)
